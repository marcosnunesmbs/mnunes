{
    "name": "site-2026",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/output.css --minify",
        "build:js": "esbuild assets/js/main.js --bundle --minify --outfile=assets/js/bundle.min.js",
        "build": "npm run build:css && npm run build:js",
        "watch:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/output.css --watch",
        "watch:js": "esbuild assets/js/main.js --bundle --outfile=assets/js/bundle.min.js --watch",
        "dev": "npm run watch:css & npm run watch:js"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.1.18",
        "esbuild": "^0.27.2",
        "tailwindcss": "^4.1.18"
    }
}
